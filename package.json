{
  "name": "minecooker-bot",
  "version": "1.0.0",
  "description": "Modular high-availability Mineflayer bot",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "check": "node --check src/index.js && node --check src/core/BotManager.js && node --check src/core/TaskQueue.js && node --check src/modules/*.js && node --check src/utils/*.js && node --check src/config/defaultConfig.js"
  },
  "dependencies": {
    "mineflayer": "4.32.0",
    "mineflayer-armor-manager": "2.0.1",
    "mineflayer-pathfinder": "latest",
    "prismarine-block": "1.21.0",
    "prismarine-item": "1.17.0",
    "vec3": "0.1.10",
    "mineflayer-tool": "latest",
    "mineflayer-auto-eat": "latest",
    "@nxg-org/mineflayer-custom-pvp": "latest",
    "mineflayer-collectblock": "latest"
  },
  "engines": {
    "node": ">=18.18"
  }
}
